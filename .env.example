# ============================================================
# Environment variables — copy to .env and fill in values
# DO NOT commit .env to git
# ============================================================

# Your wallet private key (no 0x prefix)
PRIVATE_KEY=your_private_key_here

# Sepolia RPC endpoint (e.g. from Alchemy or Infura)
# https://app.alchemy.com  or  https://infura.io
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_api_key_here

# Etherscan API key for contract verification
# https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Set to "true" to enable gas reporting on test runs
REPORT_GAS=false
